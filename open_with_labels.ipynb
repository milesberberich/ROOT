   "source": [
    "def open_with_labels(path): # small helper function, so the band labels dont get deleted during rioxarray.open_rasterio()\n",
    "    da = rioxarray.open_rasterio(path)\n",
    "    if 'long_name' in da.attrs:\n",
    "        da = da.assign_coords(band=list(da.attrs['long_name']))\n",
    "    return da"
   ]
  }
